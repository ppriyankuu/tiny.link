generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int     @id @default(autoincrement())
  username String  @unique
  password String
  links    Links[]
}

model Links {
  id     Int    @id @default(autoincrement())
  userId Int
  title  String
  link   String
  status Status
  user   User   @relation(fields: [userId], references: [id])
}

enum Status {
  active
  inactive
}
